---
import BaseLayout from '../layouts/BaseLayout.astro';

const done = [
  'Zahlreiche zentrale KI-Begriffe, jeweils vollständig erklärt',
  'Domänenbrillen: Automotive, Public Sector, Healthcare und Finance & Banking',
  'Jede Analogie mit einer ehrlichen Grenze (limits)',
  'Clientseitige Volltextsuche und Facettenfilter',
  'Diagramme zum KI-Ökosystem, zur Tokenökonomie und mehr',
];

const v2 = [
  'Weitere Domänenbrillen über die bestehenden hinaus',
  'Mehr Einstiegsbegriffe (basic/intermediate), um die Breite für Nicht-Fachleute zu erhöhen',
  'Vertiefte Querverweise und geführte Lernpfade',
  'Mehrsprachigkeit (DE/EN)',
];
---
<BaseLayout title="Roadmap" description="Was in v1 enthalten ist und was für v2 geplant ist.">
  <section class="section container prose">
    <h1>Roadmap</h1>
    <p class="lead">v1 ist ein bewusst tiefer, vertikaler Schnitt: lieber Begriffe vollständig über mehrere Brillen als viele Begriffe halb.</p>

    <h2>In v1 enthalten</h2>
    <ul>
      {done.map((d) => <li>{d}</li>)}
    </ul>

    <h2>Geplant für v2</h2>
    <ul>
      {v2.map((d) => <li>{d}</li>)}
    </ul>

    <h2>Idee: KI-Lab</h2>
    <p>
      Ein interaktives KI-Lab zum spielerischen Ausprobieren von Konzepten (z.&nbsp;B. Tokenisierung oder
      Kontextfenster) ist als Idee vorgemerkt, aber bewusst <strong>nicht Teil von v1</strong>.
    </p>
  </section>
</BaseLayout>

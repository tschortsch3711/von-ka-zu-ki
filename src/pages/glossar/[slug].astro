---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TokenPipeline from '../../components/TokenPipeline.astro';
import AgentLoop from '../../components/AgentLoop.astro';
import glossary from '../../data/glossary.json';
import domains from '../../data/domains.json';
import type { GlossaryTerm, Domain } from '../../data/types';
import { link, termHref } from '../../lib/paths';

export function getStaticPaths() {
  const terms = glossary as GlossaryTerm[];
  return terms.map((term) => ({ params: { slug: term.slug }, props: { term } }));
}

const { term } = Astro.props as { term: GlossaryTerm };
const allTerms = glossary as GlossaryTerm[];
const lenses = domains as Domain[];
const byKey = Object.fromEntries(lenses.map((d) => [d.key, d]));

const difficultyLabel: Record<string, string> = { basic: 'Einstieg', intermediate: 'Aufbau', advanced: 'Vertiefung' };
const relevanceLabel: Record<string, string> = { low: 'gering', medium: 'mittel', high: 'hoch' };

// relatedTerms aufloesen (nur existierende Begriffe verlinken)
const related = term.relatedTerms
  .map((id) => allTerms.find((t) => t.id === id || t.slug === id))
  .filter((t): t is GlossaryTerm => Boolean(t));

const analogyEntries = Object.entries(term.domainAnalogies);

const bestByKey = Object.fromEntries(lenses.map((d) => [d.key, new Set(d.bestExplainedTerms)]));
const isBest = (key: string) => bestByKey[key]?.has(term.id) || bestByKey[key]?.has(term.slug);

// schema.org DefinedTerm: macht jede Begriffsseite für Suchmaschinen als Glossar-Eintrag erkennbar.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: term.term,
  ...(term.aliases.length > 0 ? { alternateName: term.aliases } : {}),
  description: term.shortDefinition,
  inLanguage: 'de',
  url: new URL(link(`glossar/${term.slug}/`), Astro.site).href,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'Von K.A. zu K.I.',
    url: new URL(link('glossar/'), Astro.site).href,
  },
};
---
<BaseLayout title={term.term} description={term.shortDefinition}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <article class="section container term">
    <nav class="breadcrumb" aria-label="Brotkrümelnavigation">
      <a href={link('glossar/')}>Glossar</a>
      <span aria-hidden="true"> › </span>
      <span aria-current="page">{term.term}</span>
    </nav>

    <header class="term__header">
      <div class="term__badges">
        <span class="badge badge--accent">{term.category}</span>
        <span class={`badge badge--${term.difficulty}`}>{difficultyLabel[term.difficulty] ?? term.difficulty}</span>
        <span class="badge">Enterprise-Relevanz: {relevanceLabel[term.enterpriseRelevance] ?? term.enterpriseRelevance}</span>
      </div>
      <h1>{term.term}</h1>
      {term.aliases.length > 0 && (
        <p class="muted">Auch: {term.aliases.join(', ')}</p>
      )}
      <p class="lead">{term.shortDefinition}</p>
    </header>

    <section class="prose">
      <h2>Fachliche Definition</h2>
      <p>{term.technicalDefinition}</p>

      <h2>Warum das wichtig ist</h2>
      <p>{term.whyItMatters}</p>

      <h2>Häufige Missverständnisse</h2>
      <ul class="checks">
        {term.misconceptions.map((m) => <li>{m}</li>)}
      </ul>
    </section>

    {term.id === 'token' && (
      <section style="margin-top:2rem">
        <h2>Wie aus einer Anfrage Kosten werden</h2>
        <TokenPipeline />
      </section>
    )}
    {term.id === 'agent' && (
      <section style="margin-top:2rem">
        <h2>Wie ein Agent iterativ arbeitet</h2>
        <AgentLoop />
      </section>
    )}

    <section>
      <h2>Perspektiven</h2>
      <p class="muted">Dieselbe Sache, aus bekannten Blickwinkeln erklärt. Jede Analogie hat eine ehrliche Grenze.</p>

      <div class="lens-tabs" role="tablist" aria-label="Perspektive wählen" id="lens-tabs">
        {analogyEntries.map(([key], i) => {
          const d = byKey[key];
          return (
            <button
              class:list={['lens-tab', isBest(key) ? 'lens-tab--best' : '']}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`lens-panel-${key}`}
              id={`lens-tab-${key}`}
              type="button"
            >
              {isBest(key) && <span class="best-dot" aria-hidden="true">●</span>}
              <span aria-hidden="true">{d?.icon ?? '🔭'}</span> {d?.name ?? key}
            </button>
          );
        })}
      </div>

      <div class="lens-grid" style="margin-top:1rem">
        {analogyEntries.map(([key, a]) => {
          const d = byKey[key];
          return (
            <div
              class:list={['lens-card', isBest(key) ? 'lens-card--best' : '']}
              role="tabpanel"
              id={`lens-panel-${key}`}
              aria-labelledby={`lens-tab-${key}`}
              data-lens-panel
            >
              <h3><span aria-hidden="true">{d?.icon ?? '🔭'}</span> {d?.name ?? key}</h3>
              <p><strong>{a.analogy}</strong></p>
              <p class="muted">{a.explanation}</p>
              <p class="lens-limit"><strong>⚠ Wo die Analogie an Grenzen stößt</strong>{a.limits}</p>
            </div>
          );
        })}
      </div>
      {analogyEntries.some(([key]) => isBest(key)) && (
        <p class="lens-legend">
          <span class="lens-legend__dot" aria-hidden="true">●</span>
          Blauer Hintergrund und Punkt markieren die Perspektive, die diesen Begriff besonders anschaulich erklärt.
        </p>
      )}
    </section>

    {related.length > 0 && (
      <section style="margin-top:2.5rem">
        <h2>Verwandte Begriffe</h2>
        <div class="related-list">
          {related.map((r) => <a class="badge badge--accent related-pill" href={termHref(r.slug)}>{r.term}</a>)}
        </div>
      </section>
    )}
  </article>

  <style>
    .term__header { margin-bottom: 2rem; }
    .term__badges { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.8rem; }
    .related-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .related-pill { font-size: 0.85rem; text-transform: none; letter-spacing: 0; padding: 0.4em 0.8em; }
    .related-pill:hover { text-decoration: none; filter: brightness(1.05); }
  </style>

  <script is:inline>
    (function () {
      var tablist = document.getElementById('lens-tabs');
      var tabs = Array.prototype.slice.call(document.querySelectorAll('.lens-tab'));
      var panels = Array.prototype.slice.call(document.querySelectorAll('[data-lens-panel]'));
      if (!tablist || !tabs.length) return;

      // Ursprüngliche ARIA-Bezüge sichern, um sie im Tab-Modus wiederherzustellen.
      var tabControls = tabs.map(function (t) { return t.getAttribute('aria-controls'); });
      var panelLabels = panels.map(function (p) { return p.getAttribute('aria-labelledby'); });
      var mq = window.matchMedia('(max-width: 639px)');

      function currentIndex() {
        for (var i = 0; i < tabs.length; i++) {
          if (tabs[i].getAttribute('aria-selected') === 'true') return i;
        }
        return 0;
      }

      function selectTab(index, focus) {
        tabs.forEach(function (t, i) {
          var sel = i === index;
          t.setAttribute('aria-selected', sel ? 'true' : 'false');
          t.setAttribute('tabindex', sel ? '0' : '-1');
          if (sel && focus) t.focus();
        });
        panels.forEach(function (p, i) {
          if (i === index) p.removeAttribute('hidden');
          else p.setAttribute('hidden', '');
        });
        try { localStorage.setItem('vkzk-lens-tab', String(index)); } catch (e) {}
      }

      // Mobile: echtes Tab-Widget (Roving-Tabindex + nur ein Panel sichtbar).
      function enableTabMode() {
        tablist.setAttribute('role', 'tablist');
        tabs.forEach(function (t, i) {
          t.setAttribute('role', 'tab');
          if (tabControls[i]) t.setAttribute('aria-controls', tabControls[i]);
        });
        panels.forEach(function (p, i) {
          p.setAttribute('role', 'tabpanel');
          p.setAttribute('tabindex', '0');
          if (panelLabels[i]) p.setAttribute('aria-labelledby', panelLabels[i]);
        });
        var saved = 0;
        try { saved = parseInt(localStorage.getItem('vkzk-lens-tab') || '0', 10) || 0; } catch (e) {}
        selectTab(saved >= 0 && saved < tabs.length ? saved : 0, false);
      }

      // Desktop: alle Panels sichtbar nebeneinander — Tab-Rollen wären hier irreführend, also entfernen.
      function disableTabMode() {
        tablist.removeAttribute('role');
        tabs.forEach(function (t) {
          t.removeAttribute('role');
          t.removeAttribute('aria-selected');
          t.removeAttribute('aria-controls');
          t.removeAttribute('tabindex');
        });
        panels.forEach(function (p) {
          p.removeAttribute('hidden');
          p.removeAttribute('role');
          p.removeAttribute('tabindex');
          p.removeAttribute('aria-labelledby');
        });
      }

      function apply() {
        if (mq.matches) enableTabMode();
        else disableTabMode();
      }

      tabs.forEach(function (tab, i) {
        tab.addEventListener('click', function () { if (mq.matches) selectTab(i, false); });
      });

      tablist.addEventListener('keydown', function (e) {
        if (!mq.matches) return;
        var idx = currentIndex();
        var next = null;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = (idx + 1) % tabs.length;
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = (idx - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = tabs.length - 1;
        if (next !== null) { e.preventDefault(); selectTab(next, true); }
      });

      apply();
      mq.addEventListener('change', apply);
    })();
  </script>
</BaseLayout>

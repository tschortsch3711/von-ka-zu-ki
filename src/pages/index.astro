---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GlossaryCard from '../components/GlossaryCard.astro';
import DomainLensCard from '../components/DomainLensCard.astro';
import EcosystemMap from '../components/EcosystemMap.astro';
import glossary from '../data/glossary.json';
import domains from '../data/domains.json';
import paths from '../data/paths.json';
import type { GlossaryTerm, Domain, LearningPath } from '../data/types';
import { link, lernpfadHref } from '../lib/paths';

const terms = glossary as GlossaryTerm[];
const lenses = domains as Domain[];
const realPaths = (paths as LearningPath[]).filter((p) => !p.isMetaCard);

// Ein Pool je Schwierigkeitsgrad (Einstieg/Aufbau/Vertiefung). Die konkrete Tagesauswahl
// trifft das Inline-Skript unten clientseitig (Wechsel um UTC-Mitternacht, unabhängig vom Build).
const featuredPools: { level: GlossaryTerm['difficulty']; offset: number }[] = [
  { level: 'basic', offset: 0 },
  { level: 'intermediate', offset: 1 },
  { level: 'advanced', offset: 2 },
];
const poolOf = (level: GlossaryTerm['difficulty']) => terms.filter((t) => t.difficulty === level);
---
<BaseLayout
  title="Von K.A. zu K.I."
  description="Ein analogiebasiertes KI-Glossar: zentrale KI-Begriffe fachlich korrekt erklärt, greifbar gemacht über mehrere Perspektiven, mit Volltextsuche, Filtern und geführten Lernpfaden."
>
  <Hero />

  <section class="section container">
    <h2>Wo willst du einsteigen?</h2>
    <p class="lead">Du musst nicht vorne anfangen. Nimm den Weg, der sich richtig anfühlt.</p>
    <div class="grid grid--3" style="margin-top:1.5rem">
      <a class="card path-card" href={link('glossar/')}>
        <h3><span aria-hidden="true">📚</span> Glossar durchsuchen</h3>
        <p class="muted">Alle Begriffe mit Definition, typischen Missverständnissen und mehreren Perspektiven – durchsuchbar per Volltextsuche und Filter.</p>
      </a>
      <a class="card path-card" href={link('domaenen/')}>
        <h3><span aria-hidden="true">🔭</span> Perspektiven wechseln</h3>
        <p class="muted">Dieselben Begriffe aus wechselnden Berufsperspektiven – je nach Branche erklärt sich ein Konzept ganz anders.</p>
      </a>
      <a class="card path-card" href={link('lernpfade/')}>
        <h3><span aria-hidden="true">🎓</span> Lernpfade entdecken</h3>
        <p class="muted">Geführte Pfade für Management, IT und Einsteiger – Schlüsselbegriffe in sinnvoller, aufbauender Reihenfolge.</p>
      </a>
    </div>
  </section>

  <section class="section container">
    <h2>Ausgewählte Begriffe</h2>
    <p class="lead">Frisch herausgegriffen: drei Begriffe für einen kurzen Moment Neugier.</p>
    <div class="grid grid--3 featured" style="margin-top:1.5rem">
      {featuredPools.map(({ level, offset }) => {
        const pool = poolOf(level);
        return (
          <div class="featured-slot" data-offset={offset} data-size={pool.length}>
            {pool.map((term) => (
              <div class="featured-card" hidden>
                <GlossaryCard term={term} domains={lenses} />
              </div>
            ))}
          </div>
        );
      })}
    </div>
    <noscript>
      <style>.featured-slot > .featured-card:first-child { display: block; }</style>
    </noscript>
    <script is:inline>
      (function () {
        // Tageswechsel um Mitternacht UTC, unabhängig vom Build-Zeitpunkt.
        var day = Math.floor(Date.now() / 86400000);
        document.querySelectorAll('.featured-slot').forEach(function (slot) {
          var size = parseInt(slot.getAttribute('data-size') || '0', 10);
          if (!size) return;
          var offset = parseInt(slot.getAttribute('data-offset') || '0', 10);
          var idx = (day + offset) % size;
          slot.querySelectorAll('.featured-card').forEach(function (card, i) {
            if (i === idx) card.removeAttribute('hidden');
            else card.setAttribute('hidden', '');
          });
        });
      })();
    </script>
    <p style="margin-top:1.2rem"><a class="btn" href={link('glossar/')}>Alle Begriffe ansehen →</a></p>
  </section>

  <section class="section container">
    <h2>Derselbe Begriff, ein neuer Blickwinkel</h2>
    <p class="lead">Aus welcher Berufswelt du auch kommst – hier triffst du KI-Begriffe in deiner eigenen Sprache wieder.</p>
    <div class="grid grid--2" style="margin-top:1.5rem">
      {lenses.map((domain) => <DomainLensCard domain={domain} />)}
    </div>
  </section>

  <section class="section container">
    <h2>Geführte Lernpfade</h2>
    <p class="lead">Lieber an der Hand genommen? Drei Pfade bündeln die wichtigsten Begriffe in sinnvoller, aufbauender Reihenfolge.</p>
    <div class="grid grid--3" style="margin-top:1.5rem">
      {realPaths.map((p) => (
        <a class="card path-card" href={lernpfadHref(p.slug)}>
          <h3><span aria-hidden="true">{p.icon}</span> {p.name}</h3>
          <p class="muted">{p.description}</p>
        </a>
      ))}
    </div>
    <p style="margin-top:1.2rem"><a class="btn" href={link('lernpfade/')}>Alle Lernpfade ansehen →</a></p>
  </section>

  <section class="section container">
    <h2>Wissenstests</h2>
    <p class="lead">Sitzt das Gelernte? Prüf dich selbst – die Fragen werden bei jedem Start neu zusammengestellt.</p>
    <div class="grid grid--2" style="margin-top:1.5rem">
      <a class="card path-card" href={link('quiz/')}>
        <h3><span aria-hidden="true">🧩</span> Begriff erraten</h3>
        <p class="muted">Beschreibung lesen, den passenden Begriff aus vier Optionen wählen.</p>
      </a>
      <a class="card path-card" href={link('quiz/')}>
        <h3><span aria-hidden="true">⚖️</span> Mythos oder Wahrheit</h3>
        <p class="muted">Stimmt die gezeigte Definition – oder ist sie ein erfundener Mythos?</p>
      </a>
    </div>
    <p style="margin-top:1.2rem"><a class="btn" href={link('quiz/')}>Wissenstest starten →</a></p>
  </section>

  <section id="oekosystem" class="section container">
    <h2>Das KI-Ökosystem auf einen Blick</h2>
    <p class="lead">Wer steuert, wer leistet die Arbeit, wer prüft – und wie hängt das zusammen.</p>
    <div style="margin-top:1.5rem">
      <EcosystemMap />
    </div>
  </section>

  <style>
    .path-card { color: var(--text); transition: border-color 0.15s ease, transform 0.15s ease; }
    .path-card:hover { text-decoration: none; border-color: var(--accent); transform: translateY(-2px); }
    .path-card h3 { margin: 0 0 0.5rem; }
    .path-card p { margin: 0; }
    /* Jeder Slot ist eine Grid-Zelle; sichtbar ist je genau eine Karte (Tagesauswahl per Skript). */
    .featured-slot { height: 100%; }
    .featured-card { height: 100%; }
  </style>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DomainLensCard from '../../components/DomainLensCard.astro';
import DomainMatrix from '../../components/DomainMatrix.astro';
import domains from '../../data/domains.json';
import type { Domain } from '../../data/types';

const lenses = domains as Domain[];
---
<BaseLayout title="Perspektiven" description="Dieselben KI-Begriffe aus vier Blickwinkeln: Automotive, Public Sector, Healthcare und Finance & Banking.">
  <section class="section container">
    <h1>Perspektiven</h1>
    <p class="lead">Dieselbe Sache, verschiedene Blickwinkel. Jede Perspektive beantwortet dieselben Leitfragen:</p>
    <ul class="lead leitfragen">
      <li>Warum eignet sie sich als Analogie?</li>
      <li>Wofür ist sie hilfreich – und wo trägt sie?</li>
      <li>Welche Begriffe lassen sich besonders gut darüber erklären?</li>
      <li>Wo stößt sie an ihre Grenzen?</li>
    </ul>
    <div class="grid grid--2" style="margin-top:2rem">
      {lenses.map((domain) => <DomainLensCard domain={domain} />)}
    </div>
  </section>

  <section class="section container">
    <h2>Welche Perspektive erklärt welchen Begriff besonders gut?</h2>
    <p class="lead">Die Matrix zeigt, wo eine Perspektive besonders trägt. Kein Begriff ist auf eine Perspektive beschränkt.</p>
    <div style="margin-top:1.5rem"><DomainMatrix /></div>
  </section>

  <style>
    .leitfragen { margin: 0.6rem 0 0; padding-left: 1.3rem; }
    .leitfragen li { margin-bottom: 0.3rem; }
  </style>
</BaseLayout>

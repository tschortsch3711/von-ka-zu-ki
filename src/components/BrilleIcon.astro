    <circle cx="17.5" cy="18" r="1.5"/>
  `,
  publicSector: `
    <path d="M12 2L2 8h20L12 2z"/>
    <line x1="2" y1="8" x2="22" y2="8"/>
    <line x1="6" y1="9" x2="6" y2="19"/>
    <line x1="12" y1="9" x2="12" y2="19"/>
    <line x1="18" y1="9" x2="18" y2="19"/>
    <line x1="2" y1="19" x2="22" y2="19"/>
    <line x1="2" y1="21" x2="22" y2="21"/>
  `,
  healthcare: `
    <path d="M12 2L4 6v5c0 5.5 3.5 9.5 8 11 4.5-1.5 8-5.5 8-11V6L12 2z"/>
    <line x1="12" y1="8" x2="12" y2="16"/>
    <line x1="8" y1="12" x2="16" y2="12"/>
  `,
  finance: `
    <path d="M3 21V3"/>
    <path d="M3 21h18"/>
    <path d="M7 14h3v7H7z"/>
    <path d="M11 10h3v11h-3z"/>
    <path d="M15 6h3v15h-3z"/>
  `,
};
---
<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
  set:html={paths[domainKey] ?? ''}
/>

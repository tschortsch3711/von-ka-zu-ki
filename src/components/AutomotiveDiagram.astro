---
// Automotive-Beispieldiagramm: die Showcase-Zuordnung der Auto-Brille auf KI-Begriffe.
const mappings = [
  { icon: '🚗', label: 'Fahrzeug / Fahrer', maps: 'KI-Agent' },
  { icon: '⚙️', label: 'Motor', maps: 'Modell (LLM)' },
  { icon: '⛽', label: 'Sprit / Verbrauch', maps: 'Tokens' },
  { icon: '💳', label: 'Tankkarte', maps: 'API-Key' },
  { icon: '🛣️', label: 'Straße / Anschluss', maps: 'API / MCP' },
  { icon: '🏭', label: 'Raffinerie', maps: 'Rechenzentrum' },
  { icon: '🔧', label: 'Werkstatt', maps: 'Training / Fine-Tuning' },
  { icon: '✅', label: 'TÜV', maps: 'AI Governance' },
  { icon: '🗂️', label: 'Flottenmanager', maps: 'Unternehmen' },
];
---
<figure class="diagram-figure">
  <div class="auto-grid" role="img" aria-label="Automotive-Perspektive: Zuordnung von Auto-Begriffen zu KI-Begriffen">
    {mappings.map((m) => (
      <div class="auto-cell">
        <span class="auto-icon" aria-hidden="true">{m.icon}</span>
        <span class="auto-from">{m.label}</span>
        <span class="auto-arrow" aria-hidden="true">→</span>
        <span class="auto-to">{m.maps}</span>
      </div>
    ))}
  </div>
  <figcaption>Abb. 5 — Die Automotive-Perspektive als Showcase: bekannte Auto-Begriffe, übersetzt in KI-Begriffe. Eine Perspektive von vieren, nicht das ganze Bild.</figcaption>
</figure>

<style>
  .auto-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 560px) { .auto-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 860px) { .auto-grid { grid-template-columns: repeat(3, 1fr); } }
  .auto-cell {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }
  .auto-icon { font-size: 1.4rem; }
  .auto-from { font-weight: 600; }
  .auto-arrow { color: var(--text-muted); }
  .auto-to { color: var(--accent); font-weight: 600; margin-left: auto; text-align: right; }
</style>

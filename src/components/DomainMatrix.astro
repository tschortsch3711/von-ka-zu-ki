---
// Perspektiven-Matrix: welche Begriffe sich über welche Perspektive besonders gut erklären.
// Datengetrieben: ein Haken, wenn der Begriff in domain.bestExplainedTerms steht.
import glossary from '../data/glossary.json';
import domains from '../data/domains.json';
import type { GlossaryTerm, Domain } from '../data/types';
import { termHref } from '../lib/paths';

const terms = (glossary as GlossaryTerm[]).slice().sort((a, b) => a.term.localeCompare(b.term, 'de'));
const lenses = domains as Domain[];
const bestSets = Object.fromEntries(lenses.map((d) => [d.id, new Set(d.bestExplainedTerms)]));
const isBest = (term: GlossaryTerm, d: Domain) => bestSets[d.id].has(term.id) || bestSets[d.id].has(term.slug);
---
<figure class="diagram-figure">
  <table class="matrix">
    <caption class="sr-only">Abb. 4 — Perspektiven-Matrix: Begriffe und die besonders gut passenden Perspektiven</caption>
    <thead>
      <tr>
        <th scope="col">Begriff</th>
        {lenses.map((d) => (
          <th scope="col" class="matrix-col-head">
            <span class="th-icon" aria-hidden="true">{d.icon}</span>
            <span class="th-label">{d.name}</span>
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {terms.map((term) => (
        <tr data-href={termHref(term.slug)}>
          <th scope="row"><a href={termHref(term.slug)}>{term.term}</a></th>
          {lenses.map((d) => (
            <td class={isBest(term, d) ? 'on' : 'off'}>
              <span aria-hidden="true">{isBest(term, d) ? '●' : '·'}</span>
              <span class="sr-only">{isBest(term, d) ? 'besonders gut erklärbar' : 'erklärbar'}</span>
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
  <figcaption>Abb. 4 — Ein gefüllter Punkt markiert eine besonders tragfähige Perspektive. Jeder Begriff lässt sich über alle Perspektiven erklären.</figcaption>
</figure>

<script is:inline>
  document.querySelectorAll('.matrix tbody tr[data-href]').forEach(function (row) {
    row.addEventListener('click', function (e) {
      if (!e.target.closest('a')) window.location.href = row.dataset.href;
    });
  });
</script>

<style>
  /* min-width sorgt dafür, dass die overflow-x-Scrollfläche (.diagram-figure) sauber greift,
     statt die Spalten auf schmalen Screens zu quetschen. */
  .matrix { width: 100%; min-width: 32rem; border-collapse: collapse; font-size: 0.92rem; }
  .matrix th, .matrix td { padding: 0.55rem 0.6rem; border-bottom: 1px solid var(--border); text-align: left; }
  .matrix thead th { font-size: 0.85rem; color: var(--text-muted); vertical-align: bottom; }
  .matrix-col-head { text-align: center !important; }
  .matrix-col-head .th-icon { display: block; font-size: 1.4rem; margin-bottom: 0.25rem; }
  .matrix thead th .th-label { display: block; font-weight: 600; }
  .matrix tbody th { font-weight: 600; }
  .matrix tbody th a { color: var(--text); }
  .matrix tbody tr { cursor: pointer; }
  .matrix tbody tr:hover td,
  .matrix tbody tr:hover th { background: var(--accent-soft); }
  .matrix td { text-align: center; font-size: 1.2rem; }
  .matrix td.on { color: var(--accent); }
  .matrix td.off { color: var(--text-muted); opacity: 0.5; }
  /* .sr-only kommt global aus global.css */
</style>

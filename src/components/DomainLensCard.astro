---
import type { Domain } from '../data/types';
import { domainHref } from '../lib/paths';
import BrilleIcon from './BrilleIcon.astro';

export interface Props {
  domain: Domain;
}
const { domain } = Astro.props;
---
<a class="domain-card" href={domainHref(domain.slug)}>
  <BrilleIcon domainKey={domain.key} class="domain-card__icon" />
  <h3>{domain.name}</h3>
  <p>{domain.tagline}</p>
  <span class="domain-card__more">Brille öffnen →</span>
</a>

<style>
  .domain-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.3rem;
    box-shadow: var(--shadow);
    color: var(--text);
    height: 100%;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .domain-card:hover { text-decoration: none; border-color: var(--accent); transform: translateY(-2px); }
  .domain-card__icon { width: 2rem; height: 2rem; color: var(--accent); }
  .domain-card h3 { margin: 0; }
  .domain-card p { margin: 0; color: var(--text-muted); flex: 1; }
  .domain-card__more { font-weight: 600; color: var(--accent); }
</style>

---
import type { GlossaryTerm, Domain } from '../data/types';
import { termHref } from '../lib/paths';
import { topDomainKeys } from '../lib/rating';

export interface Props {
  term: GlossaryTerm;
  domains?: Domain[];
}
const { term, domains = [] } = Astro.props;
const relevanceLabel: Record<string, string> = { low: 'gering', medium: 'mittel', high: 'hoch' };
const difficultyLabel: Record<string, string> = { basic: 'Einstieg', intermediate: 'Aufbau', advanced: 'Vertiefung' };
const iconOf = Object.fromEntries(domains.map((d) => [d.key, d.icon]));
const nameOf = Object.fromEntries(domains.map((d) => [d.key, d.name]));
// Nur die zwei stärksten Perspektiven (höchster quality-Score) – hält die Meta-Zeile schmal.
const topKeys = topDomainKeys(term, 2);
---
<a class="glossary-card" href={termHref(term.slug)}>
  <div class="glossary-card__head">
    <h3>{term.term}</h3>
    <span class="badge badge--accent">{term.category}</span>
  </div>
  <p class="glossary-card__def">{term.shortDefinition}</p>
  <div class="glossary-card__meta">
    <span class={`badge badge--${term.difficulty}`}>{difficultyLabel[term.difficulty] ?? term.difficulty}</span>
    <span class="badge">Enterprise-Relevanz: {relevanceLabel[term.enterpriseRelevance] ?? term.enterpriseRelevance}</span>
    <span class="glossary-card__lenses" aria-label="Stärkste Perspektiven">
      {topKeys.map((k) => (
        <span title={nameOf[k] ?? k}>{iconOf[k] ?? '•'}</span>
      ))}
    </span>
  </div>
</a>

<style>
  .glossary-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem;
    box-shadow: var(--shadow);
    color: var(--text);
    height: 100%;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .glossary-card:hover { text-decoration: none; border-color: var(--accent); transform: translateY(-2px); }
  .glossary-card__head { display: flex; align-items: start; justify-content: space-between; gap: 0.6rem; }
  .glossary-card__head h3 { margin: 0; font-size: 1.1rem; flex: 1; min-width: 0; }
  .glossary-card__def { margin: 0; color: var(--text-muted); font-size: 0.95rem; flex: 1; }
  .glossary-card__meta { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; }
  .glossary-card__lenses { margin-left: auto; font-size: 1.1rem; letter-spacing: 0.1em; }
</style>

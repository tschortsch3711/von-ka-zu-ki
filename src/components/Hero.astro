---
import { link } from '../lib/paths';
---
<section class="hero">
  <div class="container">
    <p class="hero__eyebrow">Analogiebasiertes KI-Glossar</p>
    <h1 class="hero__title">Von K.A. <span aria-hidden="true">🤷‍♂️❓</span> zu K.I. <span aria-hidden="true">💡❗</span></h1>
    <p class="hero__subtitle">Ein universelles, analogiebasiertes KI-Glossar mit Domänenbrillen.</p>
    <p class="lead hero__lead">
      Ein Begriff, eine fachlich korrekte Definition, mehrere Erklärwelten. Wir machen zentrale
      KI-Begriffe über bekannte Domänen greifbar: Automotive, Public Sector und Healthcare.
    </p>
    <div class="hero__cta">
      <a class="btn btn--primary" href={link('glossar/')}>Glossar durchsuchen</a>
      <a class="btn" href={link('domaenen/')}>Domänenbrillen ansehen</a>
      <a class="btn" href={link('#oekosystem')}>KI-Ökosystem verstehen</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(2.5rem, 8vw, 5rem);
    background:
      radial-gradient(60% 120% at 80% -10%, var(--accent-soft), transparent 60%),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }
  .hero__title { margin: 0 0 0.6rem; }
  .hero__subtitle { font-size: clamp(1.05rem, 2.5vw, 1.35rem); font-weight: 600; margin: 0 0 1rem; color: var(--text); }
  .hero__lead { margin: 0 0 1.8rem; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; }
</style>
